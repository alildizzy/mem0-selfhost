# mem0-selfhost environment variables
# Copy to .env and fill in values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key (used for LLM fact extraction + embeddings)
OPENAI_API_KEY=your-openai-key-here

# Anthropic API key (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── LLM ───────────────────────────────────────────────────────────────────────

# LLM provider — use "anthropic" to activate the top_p + tool_use patch in main.py
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2

# ── Embeddings ────────────────────────────────────────────────────────────────

EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small

# ── Ports (host-side) ─────────────────────────────────────────────────────────

# Change these if you have conflicts on your machine
MEM0_PORT=8888
POSTGRES_PORT=8432
NEO4J_HTTP_PORT=8474
NEO4J_BOLT_PORT=8687

# ── Graph store ───────────────────────────────────────────────────────────────

# Patched: main.py sanitizes relationship types for valid Cypher syntax.
# Still incompatible with Anthropic LLM_PROVIDER (auto-disabled in main.py).
GRAPH_STORE_ENABLED=true
