# mem0-selfhost environment variables
# Copy to .env and fill in values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (used for LLM fact extraction via claude-haiku-4-5)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key (used for text-embedding-3-small embeddings)
OPENAI_API_KEY=your-openai-key-for-embeddings

# ── LLM ───────────────────────────────────────────────────────────────────────

# LLM provider — use "anthropic" to activate the top_p + tool_use patch in main.py
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
LLM_TEMPERATURE=0.2

# ── Embeddings ────────────────────────────────────────────────────────────────

EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small

# ── Ports (host-side) ─────────────────────────────────────────────────────────

# Change these if you have conflicts on your machine
MEM0_PORT=8888
POSTGRES_PORT=8432
NEO4J_HTTP_PORT=8474
NEO4J_BOLT_PORT=8687

# ── Graph store ───────────────────────────────────────────────────────────────

# Disabled: upstream mem0 Cypher generator emits invalid labels for user_ids with hyphens.
# Also incompatible with Anthropic tool calling format.
# Set to "true" only if you switch to openai LLM_PROVIDER AND upstream fixes the Cypher bug.
GRAPH_STORE_ENABLED=false
